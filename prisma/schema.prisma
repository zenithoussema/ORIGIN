generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              UserRole           @default(USER)
  loyaltyPoints     Int                @default(0)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  accounts          Account[]
  sessions          Session[]
  orders            Order[]
  reservations      Reservation[]
  payments          Payment[]
  wallet            Wallet?
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]
  userInteractions  UserInteraction[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@index([role, createdAt])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  description String
  price       Float
  image       String?
  video       String?
  category    MenuCategory
  isAvailable Boolean      @default(true)
  tags        String[]     @default([])
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category])
  @@index([isAvailable])
  @@index([category, isAvailable])
  @@index([price])
  @@index([deletedAt])
  @@map("menu_items")
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String
  items         Json
  totalPrice    Float
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(UNPAID)
  deliveryType  DeliveryType  @default(PICKUP)
  address       String?
  notes         String?
  customerName  String
  customerEmail String
  customerPhone String
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("orders")
}

model Payment {
  id                    String              @id @default(cuid())
  orderId               String
  userId                String
  amount                Float
  method                PaymentRecordMethod
  status                PaymentRecordStatus @default(PENDING)
  transactionId         String?
  stripePaymentIntentId String?
  metadata              Json?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  order                 Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([orderId, status])
  @@index([transactionId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Float               @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Float
  type        String
  description String
  referenceId String?
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transactions")
}

model Reservation {
  id        String            @id @default(cuid())
  userId    String?
  name      String
  date      DateTime
  time      String
  guests    Int
  status    ReservationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([userId, status])
  @@map("reservations")
}

model News {
  id        String    @id @default(cuid())
  title     String
  content   String
  image     String?
  startDate DateTime
  endDate   DateTime
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive])
  @@index([deletedAt])
  @@index([isActive, deletedAt])
  @@map("news")
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  title           String
  message         String
  type            NotificationType @default(INFO)
  read            Boolean          @default(false)
  relatedEntityId String?
  relatedType     String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([isActive])
  @@index([userId, isActive])
  @@map("push_subscriptions")
}

model Announcement {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  targetAll Boolean          @default(true)
  userIds   String[]         @default([])
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([createdAt])
  @@map("announcements")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model UserInteraction {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  itemId    String
  action    String
  category  String?
  tags      String[] @default([])
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([itemId])
  @@index([action])
  @@index([userId, action])
  @@index([userId, itemId])
  @@index([itemId, action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("user_interactions")
}

model RecommendationConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recommendation_configs")
}

enum UserRole {
  GUEST
  USER
  ADMIN
}

enum MenuCategory {
  COFFEE
  FOOD
  DESSERTS
  BEVERAGES
  SPECIALS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  COOKING
  READY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentRecordStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentRecordMethod {
  CASH
  CARD
  WALLET
}

enum DeliveryType {
  DINE_IN
  PICKUP
  DELIVERY
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  PROMO
}
